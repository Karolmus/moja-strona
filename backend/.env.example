SECRET_KEY=change-this-before-production
# Use DATABASE_URL with Neon Postgres in production.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# DATABASE_PATH is used only when DATABASE_URL is not set.
DATABASE_PATH=instance/deltasigma.sqlite3
ADMIN_EMAIL=admin@deltasigma.pl
ADMIN_PASSWORD=change-this-admin-password
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://deltasigma.pl,https://www.deltasigma.pl
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
CALCULATORS_ENABLED=false
RATE_LIMIT_ENABLED=true
MAX_CONTENT_LENGTH=32768
CONTACT_FORM_MIN_SECONDS=2
